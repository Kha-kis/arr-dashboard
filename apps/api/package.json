{
	"name": "@arr/api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"dev:launcher": "tsx src/launcher.ts",
		"build": "tsup src/index.ts src/launcher.ts --format esm --clean",
		"start": "node ./dist/launcher.js",
		"lint": "biome lint src",
		"format": "biome format src",
		"typecheck": "tsc --noEmit",
		"test": "pnpm --filter @arr/shared build && vitest",
		"db:generate": "prisma generate --schema prisma/schema.prisma",
		"db:push": "prisma db push --schema prisma/schema.prisma",
		"db:sync": "prisma db push --schema prisma/schema.prisma --skip-generate",
		"reset-admin-password": "tsx scripts/reset-admin-password.ts",
		"reset-oidc": "tsx scripts/reset-oidc.ts"
	},
	"dependencies": {
		"@arr/shared": "workspace:*",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/rate-limit": "^10.3.0",
		"@prisma/adapter-better-sqlite3": "^7.8.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@simplewebauthn/server": "^13.3.1",
		"@streamparser/json": "^0.0.22",
		"argon2": "^0.44.0",
		"arr-sdk": "^0.7.1",
		"better-sqlite3": "^12.10.0",
		"dequal": "^2.0.3",
		"dotenv": "^17.4.2",
		"fastify": "^5.8.5",
		"fastify-plugin": "^5.1.0",
		"isomorphic-dompurify": "^3.16.0",
		"marked": "^17.0.6",
		"nodemailer": "^8.0.10",
		"oauth4webapi": "^3.8.6",
		"pg": "^8.21.0",
		"pino": "^10.3.1",
		"pino-roll": "^4.0.0",
		"prisma": "^7.8.0",
		"web-push": "^3.6.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.9.3",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"@types/web-push": "^3.6.4",
		"tsup": "^8.5.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
