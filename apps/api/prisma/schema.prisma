  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, serviceType])
  @@index([userId, serviceType])
  @@map("user_custom_formats")
}

// ============================================================================
// Queue Cleaner Feature Models
// Automated cleanup of stuck/failed downloads from Sonarr/Radarr queues
// ============================================================================

/// Per-instance queue cleaner configuration (1:1 with ServiceInstance)
model QueueCleanerConfig {
  id                    String          @id @default(cuid())
  instanceId            String          @unique
  instance              ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  // Master toggle
  enabled               Boolean         @default(false)

  // Check frequency
  intervalMins          Int             @default(30)

  // Rule: Stalled downloads
  stalledEnabled        Boolean         @default(true)
  stalledThresholdMins  Int             @default(60)

  // Rule: Failed downloads
  failedEnabled         Boolean         @default(true)

  // Rule: Slow downloads
  slowEnabled           Boolean         @default(false)
  slowSpeedThreshold    Int             @default(100)     // KB/s
  slowGracePeriodMins   Int             @default(30)

  // Rule: Error pattern matching
  errorPatternsEnabled  Boolean         @default(false)
  errorPatterns         String?                           // JSON array of pattern strings

  // Removal options
  removeFromClient      Boolean         @default(false)
  addToBlocklist        Boolean         @default(true)
  searchAfterRemoval    Boolean         @default(false)

  /// qui-aware mode (Phase 2.3): when true, skip strikes on queue items whose
  /// corresponding LibraryCache.torrentState is `paused` or `error` — qui (or
  /// a human via qui) is already acting on the torrent. Opt-in, off by default
  /// to preserve existing strike behavior. No-op when the user has no qui
  /// instance configured (LibraryCache.torrentState stays NULL across rows).
  quiAwareMode          Boolean         @default(false)

  // Change category option (torrent only - usenet doesn't support this)
  // Instead of deleting, move torrent to a different category in the client
  // The actual category name is configured in Sonarr/Radarr's download client settings
  changeCategoryEnabled Boolean         @default(false)

  // Safety settings
  dryRunMode            Boolean         @default(true)    // Safe by default!
  maxRemovalsPerRun     Int             @default(10)
  minQueueAgeMins       Int             @default(5)

  // Rule: Strike system (gradual removal)
  strikeSystemEnabled   Boolean         @default(false)
  maxStrikes            Int             @default(3)
  strikeDecayHours      Int             @default(24)

  // Rule: Seeding timeout
  seedingTimeoutEnabled Boolean         @default(false)
  seedingTimeoutHours   Int             @default(72)

  // Rule: Estimated completion exceeded
  estimatedCompletionEnabled    Boolean @default(false)
  estimatedCompletionMultiplier Float   @default(2.0)

  // Rule: Import pending/blocked cleanup
  importPendingEnabled          Boolean @default(true)  // Can be disabled by user
  importPendingThresholdMins    Int     @default(60)

  // Import block cleanup aggressiveness: "safe" | "moderate" | "aggressive"
  // safe = only redundant/quality mismatch, moderate = + manual review, aggressive = + technical
  importBlockCleanupLevel       String  @default("safe")

  // Import block pattern mode: "defaults" | "include" | "exclude"
  // defaults = use built-in categorized keywords based on cleanup level
  // include = only clean if message matches one of the custom patterns
  // exclude = don't clean if message matches any custom patterns (clean everything else)
  importBlockPatternMode        String  @default("defaults")

  // Custom import block patterns (JSON array of strings)
  // Used when patternMode is "include" or "exclude"
  importBlockPatterns           String?

  // Auto-import settings (try importing before removing)
  autoImportEnabled             Boolean @default(false)  // Master toggle
  autoImportMaxAttempts         Int     @default(2)      // Give up after N failed attempts
  autoImportCooldownMins        Int     @default(30)     // Min time between attempts on same item
  autoImportSafeOnly            Boolean @default(true)   // Only import "safe" patterns
  autoImportCustomPatterns      String?                   // JSON array of custom safe patterns
  autoImportNeverPatterns       String?                   // JSON array of custom never-import patterns

  // Tag pre-filters (filter queue items before applying rules)
  tagFilterEnabled      Boolean         @default(false)
  includeTags           String?                           // JSON: [1, 5, 12] - only clean items with these tags
  excludeTags           String?                           // JSON: [3, 7] - skip items with these tags

  // Quality profile pre-filters
  profileFilterEnabled  Boolean         @default(false)
  includeProfiles       String?                           // JSON: [1, 4] - only clean items with these profiles
  excludeProfiles       String?                           // JSON: [2] - skip items with these profiles

  // Skip future episodes (Sonarr only)
  // When enabled, Sonarr queue items for episodes that haven't aired yet are skipped
  skipFutureEpisodes    Boolean         @default(true)

  // Whitelist/Ignore patterns
  whitelistEnabled      Boolean         @default(false)
  whitelistPatterns     String?                           // JSON: [{ type, pattern }]

  // State tracking
  lastRunAt             DateTime?
  lastRunItemsCleaned   Int             @default(0)
  lastRunItemsSkipped   Int             @default(0)

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([lastRunAt])
  @@map("queue_cleaner_configs")
}

/// Queue cleaner activity audit log
model QueueCleanerLog {
  id              String          @id @default(cuid())
  instanceId      String
  instance        ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  itemsCleaned    Int             @default(0)
  itemsSkipped    Int             @default(0)
  itemsWarned     Int             @default(0)       // Items that got strikes but weren't removed
  isDryRun        Boolean         @default(false)

  // Detailed results (JSON arrays)
  cleanedItems    String?                           // JSON: [{ id, title, reason }]
  skippedItems    String?                           // JSON: [{ id, title, reason }]
  warnedItems     String?                           // JSON: [{ id, title, reason, strikeCount }]

  status          String                            // "running" | "completed" | "partial" | "skipped" | "error"
  message         String?
  durationMs      Int?

  startedAt       DateTime        @default(now())
  completedAt     DateTime?

  @@index([instanceId, startedAt])
  @@index([startedAt])
  @@map("queue_cleaner_logs")
}

/// Queue cleaner strike tracking for gradual removal
model QueueCleanerStrike {
  id              String          @id @default(cuid())
  instanceId      String
  instance        ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  downloadId      String                                // ARR queue item ID (string for consistency with shared types)
  downloadTitle   String                                // For display purposes
  downloadHash    String?                               // Torrent hash for correlation

  strikeCount     Int             @default(1)
  lastRule        String                                // Which rule triggered: stalled, failed, slow, error_pattern, seeding_timeout
  lastReason      String                                // Human-readable reason

  // Auto-import attempt tracking
  importAttempts      Int       @default(0)             // Number of auto-import attempts
  lastImportAttempt   DateTime?                         // Last import attempt timestamp
  lastImportError     String?                           // Last error message from import

  firstStrikeAt   DateTime        @default(now())
  lastStrikeAt    DateTime        @updatedAt

  @@unique([instanceId, downloadId])
  @@index([instanceId, lastStrikeAt])
  @@map("queue_cleaner_strikes")
}

// ============================================================================
// Library Cleanup Feature Models
// Automated cleanup of library items based on configurable rules
// ============================================================================

/// Per-user library cleanup configuration
model LibraryCleanupConfig {
  id                String    @id @default(cuid())
  userId            String    @unique
  enabled           Boolean   @default(false)
  intervalHours     Int       @default(24)
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  dryRunMode        Boolean   @default(true)
  maxRemovalsPerRun Int       @default(50)
  requireApproval   Boolean   @default(false)
  /// When true, cleanup proposals exclude items currently seeding via qui
  /// (LibraryCache.torrentState IN ['seeding', 'downloading']). Default false
  /// for backward compatibility — existing rules don't silently change
  /// behavior. Operators with qui configured can opt in to honor seeding
  /// obligations (private trackers, ratio targets, community seeding norms).
  /// No-op when the user has no qui instance configured.
  respectQuiSeeding Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules     LibraryCleanupRule[]
  approvals LibraryCleanupApproval[]
  logs      LibraryCleanupLog[]

  @@map("library_cleanup_configs")
}

/// Individual cleanup rules within a configuration
model LibraryCleanupRule {
  id                String   @id @default(cuid())
  configId          String
  name              String
  enabled           Boolean  @default(true)
  priority          Int      @default(0)
  ruleType          String                     // "age", "size", "plex_last_watched", etc.
  parameters        String                     // JSON blob of rule-specific parameters
  serviceFilter     String?                    // JSON array of service types
  instanceFilter    String?                    // JSON array of instance IDs
  excludeTags       String?                    // JSON array of tag names to exclude
  excludeTitles     String?                    // JSON array of title patterns to exclude
  plexLibraryFilter String?                    // JSON array of Plex section names
  action            String   @default("delete") // "delete" | "unmonitor" | "delete_files"
  operator          String?                    // "AND" | "OR" for composite rules
  conditions        String?                    // JSON array of sub-conditions
  retentionMode     Boolean  @default(false)   // true = retention (protect items), false = cleanup (flag items)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  config LibraryCleanupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@map("library_cleanup_rules")
}

/// Pending approval items for library cleanup
model LibraryCleanupApproval {
  id              String    @id @default(cuid())
  configId        String
  instanceId      String                       // Denormalized for quick lookup
  arrItemId       Int
  itemType        LibraryItemType              // movie | series
  title           String
  matchedRuleId   String
  matchedRuleName String                       // Denormalized
  reason          String
  action          String?  @default("delete")
  sizeOnDisk      BigInt
  year            Int?
  rating          Float?
  status          String   @default("pending") // "pending" | "approved" | "rejected" | "executing" | "executed" | "expired"
  reviewedAt      DateTime?
  executedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  config LibraryCleanupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId, status])
  @@index([expiresAt])
  @@map("library_cleanup_approvals")
}

/// Library cleanup activity audit log
model LibraryCleanupLog {
  id                String    @id @default(cuid())
  configId          String
  isDryRun          Boolean
  status            String                     // "completed" | "partial" | "error"
  itemsEvaluated    Int
  itemsFlagged      Int
  itemsRemoved      Int
  itemsUnmonitored  Int
  itemsFilesDeleted Int
  itemsSkipped      Int
  details           String?                    // JSON array of detail objects
  error             String?
  prefetchHealth    String?                    // JSON: { seerr, tautulli, plex } status
  warnings          String?                    // JSON array of warning strings
  durationMs        Int
  startedAt         DateTime
  completedAt       DateTime?

  config LibraryCleanupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId, startedAt])
  @@map("library_cleanup_logs")
}

// ============================================================================
// Notification Feature Models
// Push notifications and channel management
// ============================================================================

/// Notification channel configuration (email, webhook, browser push, etc.)
model NotificationChannel {
  id               String    @id @default(cuid())
  userId           String
  name             String
  type             String                      // "BROWSER_PUSH", "WEBHOOK", etc.
  enabled          Boolean   @default(true)
  encryptedConfig  String                      // AES-256-GCM ciphertext of JSON config
  configIv         String                      // IV for encryptedConfig
  lastTestedAt     DateTime?
  lastTestResult   String?
  lastSentAt       DateTime?
  lastSendResult   String?                     // "success" | error message
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions NotificationSubscription[]

  @@index([userId])
  @@map("notification_channels")
}

/// Event subscriptions per notification channel
model NotificationSubscription {
  channelId       String
  eventType       String                             // "HUNT_COMPLETED", "BACKUP_FAILED", etc.

  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, eventType])
  @@map("notification_subscriptions")
}

/// Notification delivery log
model NotificationLog {
  id          String   @id @default(cuid())
  channelId   String
  channelType String                           // Denormalized channel type at time of send
  eventType   String
  title       String
  body        String
  status      String                           // "sent" | "failed" | "dead_letter"
  error       String?
  retryCount  Int      @default(0)
  sentAt      DateTime @default(now())

  @@index([channelId])
  @@index([sentAt])
  @@index([eventType])
  @@index([channelId, eventType, status, sentAt])
  @@map("notification_logs")
}

/// VAPID keys for Web Push notifications (singleton)
model VapidKeys {
  id                  Int    @id @default(1)   // Singleton: always 1
  publicKey           String
  encryptedPrivateKey String                   // AES-256-GCM encrypted
  privateKeyIv        String                   // IV for encryptedPrivateKey

  @@map("vapid_keys")
}

/// User-defined notification rules for suppression, throttling, and routing
model NotificationRule {
  id               String   @id @default(cuid())
  userId           String
  name             String
  enabled          Boolean  @default(true)
  priority         Int      @default(0)          // Lower = higher priority
  action           String                        // "suppress" | "throttle" | "route" | "quiet_hours"
  conditions       String                        // JSON: Array<{field, operator, value}>
  targetChannelIds String?                       // JSON: string[] — for "route" action
  throttleMinutes  Int?                          // For "throttle" action
  quietHoursStart  String?                       // "HH:MM" 24h format — for "quiet_hours" action
  quietHoursEnd    String?                       // "HH:MM" 24h format — for "quiet_hours" action
  quietHoursTimezone String?                     // IANA timezone (e.g., "America/New_York")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_rules")
}

/// Per-event-type aggregation configuration
model NotificationAggregationConfig {
  id            String  @id @default(cuid())
  userId        String
  eventType     String                           // e.g., "HUNT_CONTENT_FOUND"
  windowSeconds Int     @default(300)            // Aggregation window (5min default)
  maxBatchSize  Int     @default(10)             // Flush threshold
  enabled       Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@map("notification_aggregation_configs")
}

