  watchedByUsers  String                       // JSON array of usernames

  instance ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, tmdbId, mediaType])
  @@index([instanceId])
  @@map("tautulli_cache")
}

// ============================================================================
// Cache Refresh Status
// Tracks the last refresh result for each cache type per instance
// ============================================================================

model CacheRefreshStatus {
  id               String    @id @default(cuid())
  instanceId       String
  cacheType        String    // "plex" | "tautulli" | "plex_episode"
  lastRefreshedAt  DateTime
  lastResult       String    // "success" | "error"
  lastErrorMessage String?
  itemCount        Int       @default(0)

  instance ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, cacheType])
  @@map("cache_refresh_status")
}

// ============================================================================
// Session Snapshots
// Periodic snapshots of Plex session data for trend analytics
// ============================================================================

model SessionSnapshot {
  id                String   @id @default(cuid())
  instanceId        String
  capturedAt        DateTime @default(now())
  concurrentStreams Int
  totalBandwidth    Int      @default(0)  // kbps
  lanBandwidth      Int      @default(0)
  wanBandwidth      Int      @default(0)
  directPlayCount   Int      @default(0)
  transcodeCount    Int      @default(0)
  directStreamCount Int      @default(0)
  sessionsJson      String   // JSON detail array

  instance ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, capturedAt])
  @@index([capturedAt])
  @@map("session_snapshots")
}

// ============================================================================
// TRaSH Naming Scheme Config
// Per-instance naming scheme preferences for TRaSH Guides deployment
// ============================================================================

/// Per-instance naming config for TRaSH Guides naming schemes
model NamingConfig {
  id                 String    @id @default(cuid())
  instanceId         String    @unique
  userId             String
  serviceType        String                    // "RADARR" | "SONARR"
  selectedPresets    String                    // JSON: NamingSelectedPresets object
  syncStrategy       String    @default("manual") // "auto" | "manual" | "notify"
  lastDeployedAt     DateTime?
  lastDeployedHash   String?
  lastDeployStatus   String?                   // "SUCCESS" | "FAILED" | "ROLLED_BACK"
  lastDeployError    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  instance ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("naming_configs")
}

// ============================================================================
// Naming Deploy History
// Audit trail for naming config deployments with pre-deploy snapshots for rollback.
// ============================================================================

model NamingDeployHistory {
  id               String    @id @default(cuid())
  instanceId       String
  userId           String
  deployedAt       DateTime  @default(now())
  status           String                        // "SUCCESS" | "FAILED" | "ROLLED_BACK"
  selectedPresets  String                        // JSON: NamingSelectedPresets
  resolvedPayload  String                        // JSON: the patch sent to the instance
  deployedHash     String?
  previousConfig   String?                       // JSON: full pre-deploy snapshot for rollback
  changedFields    Int
  totalFields      Int
  errorMessage     String?
  rolledBack       Boolean   @default(false)
  rolledBackAt     DateTime?

  instance ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([instanceId, deployedAt])
  @@index([userId])
  @@map("naming_deploy_history")
}

// ============================================================================
// Seerr Action Audit Log
// Tracks user actions performed via the Seerr integration (approve, decline, etc.)
// ============================================================================

model SeerrActionLog {
  id          String   @id @default(cuid())
  instanceId  String
  userId      String
  action      String   // "approve_request" | "decline_request" | "delete_request" | "retry_request" | "update_issue_status" | "add_issue_comment"
  targetType  String   // "request" | "issue"
  targetId    String   // The Seerr resource ID
  detail      String?  // JSON: additional context
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())

  instance ServiceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("seerr_action_logs")
}

// ============================================================================
// Label Sync — generic tag/label rules across media services (issue #384)
// ============================================================================

/// Per-user rule mapping a tag/label on one media service to a tag/label on
/// another. Sub-arc 1 ships the generalized schema; sub-arcs 2-3 expand
/// destinations (Jellyfin/Emby, *arr) and sources (Plex/Jellyfin/Emby).
///
/// At rule execution time, source items are enumerated, matched to the
/// destination's items (by tmdbId for movies/TV), and the destination tag
/// is applied. See lib/plex-label-sync/execute-rule.ts for the engine.
model LabelSyncRule {
  id                String   @id @default(cuid())
  userId            String
  name              String
  enabled           Boolean  @default(true)

  // Source (where to read the tag from)
  sourceService     String                   // "sonarr" | "radarr" | (future: "lidarr" | "plex" | "jellyfin" | "emby")
  sourceInstanceId  String?                  // null = match all instances of sourceService
  sourceTagName     String                   // tag/label name on the source

  // Destination (where to apply the matching tag)
  destService       String   @default("plex") // "plex" | (future: "jellyfin" | "emby" | "sonarr" | "radarr" | "lidarr")
  destInstanceId    String                   // which destination instance to apply on
  destTagName       String                   // tag/label name to apply (created if absent)

  lastRunAt         DateTime?
  lastRunStatus     String?                  // "success" | "partial" | "failed"
  lastRunMessage    String?                  // count summary or failure reason
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("label_sync_rules")
}

/// Auto-tagger rule — applies a tag to LibraryCache items matching the criteria DSL.
/// Reuses the same rule-criteria types as LibraryCleanupRule (ruleType, parameters,
/// conditions, operator) so the rule expressiveness is at parity. Differs in action:
/// instead of delete/unmonitor, it applies `tagName` to the matched items via
/// the source-side *arr tag-write infrastructure.
model AutoTagRule {
  id                String   @id @default(cuid())
  userId            String
  name              String
  enabled           Boolean  @default(true)

  // Criteria DSL (mirrors LibraryCleanupRule)
  ruleType          String                     // "age" | "size" | "genre" | "composite" | …
  parameters        String                     // JSON blob, validated against ruleParamSchemaMap
  operator          String?                    // "AND" | "OR" for composite rules
  conditions        String?                    // JSON array of sub-conditions when operator set

  // Scope filters (which items the rule sees — same shape as LibraryCleanupRule)
  serviceFilter     String?                    // JSON array of service types
  instanceFilter    String?                    // JSON array of instance IDs
  excludeTags       String?                    // JSON array of arr tag IDs to skip
  excludeTitles     String?                    // JSON array of title regex patterns to skip
  plexLibraryFilter String?                    // JSON array of Plex section names

  // Action
  tagName           String                     // Tag/label to apply on matching items

  // Run telemetry (mirrors LabelSyncRule's run reporting model)
  lastRunAt         DateTime?
  lastRunStatus     String?                    // "success" | "partial" | "failed"
  lastRunMessage    String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auto_tag_rules")
}

/// Cached membership of a TMDb curated list. One row per (userId, listId, tmdbId).
/// Refreshed by the TMDb list cache scheduler every 4h. Used by the
/// `tmdb_list_member` rule type's evaluator.
model TmdbListCache {
  id          String   @id @default(cuid())
  userId      String
  listId      String                       // TMDb list id (stringified for flexibility)
  tmdbId      Int                          // movie/TV item id from TMDb
  mediaType   String                       // "movie" | "series"
  title       String                       // denormalized for display in explain UIs
  refreshedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listId, tmdbId])
  @@index([userId, listId])
  @@map("tmdb_list_cache")
}

/// Cached membership of a Trakt curated list. One row per (userId, listSlug, tmdbId).
/// `listSlug` is the Trakt "username/list-slug" identifier (e.g.,
/// "trakt-official/oscar-winners"). Refreshed by the Trakt list cache
/// scheduler every 4h. Used by the `trakt_list_member` rule type's evaluator.
model TraktListCache {
  id          String   @id @default(cuid())
  userId      String
  listSlug    String                       // Trakt "username/list-slug" form
  tmdbId      Int                          // resolved from Trakt's tmdbId/imdbId mapping
  mediaType   String                       // "movie" | "series"
  title       String
  refreshedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listSlug, tmdbId])
  @@index([userId, listSlug])
  @@map("trakt_list_cache")
}

// ============================================================================
// qui Integration Logs (Phase 3.2+)
// Per-user activity timeline for the qui integration. Scheduler jobs +
// gate firings emit discrete events here so operators have a real view of
// "what is arr-dashboard doing with qui?" Surfaced by the /qui-activity page.
// ============================================================================

/// One discrete event from arr-dashboard's qui-related operations.
/// eventType vocabulary (extensible — new types can land alongside future phases):
///   - "qui_sync_complete"     — torrent-state-sync tick finished (rows touched, errors)
///   - "qui_backfill_complete" — infohash-backfill tick finished (scanned, found)
///   - "qui_aware_skip"        — queue-cleaner gate suppressed a strike (Phase 2.3)
///   - "qui_cleanup_excluded"  — library-cleanup gate filtered an item (Phase 2.2)
///   - "qui_action_*"          — operator-initiated mutations (Phase 4)
///   - "qui_event_received"    — webhook push from qui (Phase 5)
///
/// `details` is event-type-specific JSON. Retention is bounded — the
/// scheduler that emits an event also trims its own type's tail to keep
/// the table from growing unboundedly.
model QuiActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventType String   // see comment above for vocabulary
  details   String   // JSON payload, schema varies by eventType
  /// "severity" in the Prisma client and on the wire, "status" in the
  /// DB column (preserved via @map so existing rows don't need migration).
  /// The rename eliminates a vocabulary collision with QuiActionLog.status,
  /// which represents a *lifecycle* state (pending/success/failed) rather
  /// than an *observation severity* (ok/warn/error).
  severity  String   @default("ok") @map("status") // "ok" | "warn" | "error"

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("qui_activity_logs")
}

/// Per-user audit log of arr-dashboard-initiated mutations against qui torrents (Phase 4.1).
///
/// Distinct from QuiActivityLog: that table records *observed* qui automation
/// events (sync ticks, cleanup gate firings, etc.). This table records *intentional*
/// mutations the operator triggered through the dashboard — pause, resume, recheck,
/// reannounce, tag changes — so the operator has a tamper-evident record of every
/// change arr-dashboard made on their behalf.
///
/// Each row goes through `pending` → `success` or `failed`. Failed rows keep the
/// raw error string so the operator can diagnose without re-running. Rows are
/// indexed by `(userId, requestedAt)` for the My Actions feed and
/// `(serviceInstanceId, torrentHash)` for per-torrent history drill-downs.
model QuiActionLog {
  id                String           @id @default(cuid())
  userId            String
  serviceInstanceId String
  qbitInstanceId    Int              // qui's qBittorrent instance id (qui's ArrInstance.id)
  torrentHash       String           // info_hash (40-char hex for v1, 64-char for v2)
  action            String           // "pause" | "resume" | "recheck" | "reannounce" | "setTags" — must stay in lockstep with `quiActionSchema` in packages/shared/src/types/qui.ts
  payload           String?          // JSON of action params (tag list, etc.); null for params-less actions
  status            String           @default("pending") // "pending" | "success" | "failed"
  error             String?          // populated on status = "failed"; null otherwise
  requestedAt       DateTime         @default(now())
  completedAt      DateTime?         // populated when status transitions to success/failed

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceInstance ServiceInstance  @relation(fields: [serviceInstanceId], references: [id], onDelete: Cascade)

  @@index([userId, requestedAt])
  @@index([serviceInstanceId, torrentHash])
  @@map("qui_action_logs")
}

/// Inbound qui webhook event log (Phase 5.1).
///
/// qui's notification system POSTs to arr-dashboard's `/api/webhooks/qui`
/// endpoint whenever an event matching the registered target fires. We
/// store the raw envelope verbatim — schema evolves on qui's side, and
/// storing the full payload lets us replay or re-interpret events without
/// re-fetching anything. `serviceInstanceId` is nullable because a future
/// qui multi-instance setup might post to a user-level webhook before we
/// can correlate it to a specific instance row.
model QuiEventLog {
  id                String           @id @default(cuid())
  userId            String
  serviceInstanceId String?          // best-effort correlation to a qui instance
  eventType         String           // qui's NotificationEvent type string
  torrentHash       String?          // extracted from payload when present; powers per-torrent timeline joins
  payload           String           // raw JSON envelope from qui
  receivedAt        DateTime         @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceInstance ServiceInstance? @relation(fields: [serviceInstanceId], references: [id], onDelete: SetNull)

  @@index([userId, receivedAt])
  @@index([serviceInstanceId, eventType])
  @@map("qui_event_logs")
}
